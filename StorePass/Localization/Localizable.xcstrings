    "deleteDeviceConfirmation": {
      "comment": "Confirmation message for deleting a device",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie dieses Gerät wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete this device? This action cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que quieres eliminar este dispositivo? Esta acción no se puede deshacer."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir supprimer cet appareil ? Cette action est irréversible."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "האם אתה בטוח שברצונך למחוק מכשיר זה? פעולה זו לא ניתנת לביטול."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler eliminare questo dispositivo? Questa azione non può essere annullata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスを削除してもよろしいですか？この操作は元に戻せません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기를 삭제하시겠습니까? 이 작업은 취소할 수 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet u zeker dat u dit apparaat wilt verwijderen? Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć to urządzenie? Tej akcji nie można cofnąć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza que deseja excluir este dispositivo? Esta ação não pode ser desfeita."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить это устройство? Это действие нельзя отменить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill ta bort den här enheten? Den här åtgärden kan inte ångras."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazı silmek istediğinizden emin misiniz? Bu işlem geri alınamaz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除此设备吗？此操作无法撤销。"
          }
        }
      }
    },
