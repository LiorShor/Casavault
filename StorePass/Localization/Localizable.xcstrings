    "homesFooter": {
      "comment": "Footer text explaining homes functionality",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie auf das Häkchen, um ein Standard-Zuhause festzulegen. Passwörter werden nach dem ausgewählten Zuhause gefiltert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap the checkmark to set a default home. Passwords will be filtered by the selected home."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca la marca de verificación para establecer un hogar predeterminado. Las contraseñas se filtrarán por el hogar seleccionado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur la coche pour définir une maison par défaut. Les mots de passe seront filtrés par la maison sélectionnée."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לחץ על סימן הוי כדי להגדיר בית כברירת מחדל. סיסמאות יסוננו לפי הבית שנבחר."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca il segno di spunta per impostare una casa predefinita. Le password verranno filtrate per la casa selezionata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チェックマークをタップしてデフォルトのホームを設定します。パスワードは選択したホームでフィルタリングされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인 표시를 탭하여 기본 홈을 설정합니다. 비밀번호는 선택한 홈으로 필터링됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op het vinkje om een standaardhuis in te stellen. Wachtwoorden worden gefilterd op het geselecteerde huis."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij znacznik wyboru, aby ustawić domyślny dom. Hasła będą filtrowane według wybranego domu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque na marca de seleção para definir um lar padrão. As senhas serão filtradas pelo lar selecionado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите на галочку, чтобы установить дом по умолчанию. Пароли будут фильтроваться по выбранному дому."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck på bocken för att ange ett standardhem. Lösenord filtreras efter det valda hemmet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Varsayılan evi ayarlamak için onay işaretine dokunun. Şifreler seçilen eve göre filtrelenecek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击复选标记设置默认住宅。密码将按所选住宅进行过滤。"
          }
        }
      }
    },
