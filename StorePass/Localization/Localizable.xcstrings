    "noHomeKitDevicesDescription": {
      "comment": "Description when no HomeKit devices are found",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stellen Sie sicher, dass Sie HomeKit-Geräte in der Home-App eingerichtet haben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Make sure you have HomeKit devices set up in the Home app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Asegúrese de tener dispositivos HomeKit configurados en la app Casa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Assurez-vous d'avoir des appareils HomeKit configurés dans l'application Maison."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
