    "homeKitImportFooter": {
      "comment": "Footer text explaining import behavior",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geräte mit dem Schlüsselsymbol haben bereits gespeicherte Passwörter. Geräte werden mit leeren Passwörtern importiert, die Sie später ausfüllen können."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devices with the key icon already have passwords saved. Devices will be imported with empty passwords that you can fill in later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los dispositivos con el icono de llave ya tienen contraseñas guardadas. Los dispositivos se importarán con contraseñas vacías que puede rellenar más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les appareils avec l'icône de clé ont déjà des mots de passe enregistrés. Les appareils seront importés avec des mots de passe vides que vous pourrez remplir plus tard."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מכשירים עם סמל המפתח כבר שמורים במערכת. מכשירים ייובאו עם סיסמאות ריקות שתוכל למלא מאוחר יותר."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dispositivi con l'icona della chiave hanno già password salvate. I dispositivi verranno importati con password vuote che potrai compilare in seguito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "鍵アイコンのあるデバイスはすでにパスワードが保存されています。デバイスは空のパスワードでインポートされます。後で入力できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "열쇠 아이콘이 있는 기기는 이미 비밀번호가 저장되어 있습니다. 기기는 빈 비밀번호로 가져오며 나중에 입력할 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apparaten met het sleutelpictogram hebben al wachtwoorden opgeslagen. Apparaten worden geïmporteerd met lege wachtwoorden die u later kunt invullen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Urządzenia z ikoną klucza mają już zapisane hasła. Urządzenia zostaną zaimportowane z pustymi hasłami, które możesz uzupełnić później."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dispositivos com o ícone de chave já têm senhas salvas. Os dispositivos serão importados com senhas vazias que você pode preencher depois."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устройства с иконкой ключа уже имеют сохранённые пароли. Устройства будут импортированы с пустыми паролями, которые вы сможете заполнить позже."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Enheter med nyckelikonen har redan sparade lösenord. Enheter importeras med tomma lösenord som du kan fylla i senare."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Anahtar simgesi olan cihazların zaten kayıtlı şifreleri var. Cihazlar boş şifrelerle içe aktarılacak ve daha sonra doldurabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "带有钥匙图标的设备已保存密码。设备将以空密码导入，您可以稍后填写。"
          }
        }
      }
    },
