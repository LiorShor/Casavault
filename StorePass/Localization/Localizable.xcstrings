    "homeKitPermissionDeniedDescription": {
      "comment": "Description shown when HomeKit permission is denied",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass benötigt Zugriff auf HomeKit, um Ihre Geräte zu importieren. Öffnen Sie die Einstellungen, um den Zugriff zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass needs access to HomeKit to import your devices. Open Settings to enable access."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass necesita acceso a HomeKit para importar sus dispositivos. Abra Configuración para habilitar el acceso."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass a besoin d'accéder à HomeKit pour importer vos appareils. Ouvrez les Réglages pour activer l'accès."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass צריך גישה ל-HomeKit כדי לייבא את המכשירים שלך. עבור להגדרות כדי לאפשר גישה."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass necessita l'accesso a HomeKit per importare i tuoi dispositivi. Apri le Impostazioni per abilitare l'accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass がデバイスをインポートするには HomeKit へのアクセスが必要です。設定を開いてアクセスを有効にしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass가 기기를 가져오려면 HomeKit 접근이 필요합니다. 설정을 열어 접근을 활성화하세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass heeft toegang tot HomeKit nodig om uw apparaten te importeren. Open Instellingen om toegang in te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass potrzebuje dostępu do HomeKit, aby importować Twoje urządzenia. Otwórz Ustawienia, aby włączyć dostęp."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O StorePass precisa de acesso ao HomeKit para importar seus dispositivos. Abra as Configurações para ativar o acesso."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass требует доступа к HomeKit для импорта ваших устройств. Откройте Настройки, чтобы включить доступ."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass behöver åtkomst till HomeKit för att importera dina enheter. Öppna Inställningar för att aktivera åtkomst."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass, cihazlarınızı içe aktarmak için HomeKit'e erişim gerektirir. Erişimi etkinleştirmek için Ayarları açın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "StorePass 需要访问 HomeKit 才能导入您的设备。前往设置以启用访问权限。"
          }
        }
      }
    },
