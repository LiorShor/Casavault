          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Assicurati di avere dispositivi HomeKit configurati nell'app Home."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホームアプリで HomeKit デバイスが設定されていることを確認してください。"
